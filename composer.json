{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "barryvdh/laravel-dompdf": "^3.1",
        "filament/filament": "3.3",
        "filament/spatie-laravel-media-library-plugin": "^3.3",
        "inertiajs/inertia-laravel": "^2.0",
        "jeffgreco13/filament-breezy": "^2.6",
        "laravel/framework": "^11.0",
        "laravel/horizon": "^5.47",
        "laravel/reverb": "^1.0",
        "laravel/sanctum": "^4.0",
        "laravel/scout": "^11.2",
        "laravel/tinker": "^2.9",
        "league/flysystem-aws-s3-v3": "^3.34",
        "livewire/livewire": "3.6.4",
        "maatwebsite/excel": "^3.1",
        "meilisearch/meilisearch-php": "^1.16",
        "predis/predis": "^3.4",
        "ralphjsmit/laravel-seo": "^1.8",
        "sentry/sentry-laravel": "^4.25",
        "spatie/laravel-activitylog": "^4.12",
        "spatie/laravel-backup": "^9.3",
        "spatie/laravel-data": "^4.23",
        "spatie/laravel-medialibrary": "^11.22",
        "spatie/laravel-permission": "^6.25",
        "spatie/laravel-sitemap": "^8.0",
        "tightenco/ziggy": "^2.0",
        "twilio/sdk": "^8.11"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/breeze": "^2.4",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^10.5",
        "spatie/laravel-ignition": "^2.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --ansi"
        ]
    },
    "extra": {
        "branch-alias": {
            "dev-master": "11.x-dev"
        },
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "platform": {
            "ext-pcntl": "8.3",
            "ext-posix": "8.3"
        },
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
